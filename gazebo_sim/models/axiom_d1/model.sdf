<?xml version="1.0"?>
<sdf version="1.9">
  <model name="axiom_d1">
    <static>false</static>

    <!-- ============================================================ -->
    <!--  CHASSIS (main body)                                         -->
    <!--  400mm L x 350mm W x 150mm H, 6061-T6 aluminium frame       -->
    <!--  Total robot mass: 14 kg                                     -->
    <!-- ============================================================ -->
    <link name="chassis">
      <pose>0 0 0.075 0 0 0</pose>

      <inertial>
        <mass>10.0</mass>
        <inertia>
          <!-- Approximated as solid box: 0.4 x 0.35 x 0.15, m=10 kg -->
          <ixx>0.121</ixx>  <!-- m/12*(h^2+d^2) = 10/12*(0.35^2+0.15^2) -->
          <iyy>0.152</iyy>  <!-- m/12*(w^2+d^2) = 10/12*(0.4^2+0.15^2) -->
          <izz>0.235</izz>  <!-- m/12*(w^2+h^2) = 10/12*(0.4^2+0.35^2) -->
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="chassis_collision">
        <geometry>
          <box>
            <size>0.40 0.35 0.15</size>
          </box>
        </geometry>
      </collision>

      <visual name="chassis_visual">
        <geometry>
          <box>
            <size>0.40 0.35 0.15</size>
          </box>
        </geometry>
        <material>
          <ambient>1.0 0.5 0.0 1</ambient>
          <diffuse>1.0 0.5 0.0 1</diffuse>
          <specular>0.3 0.3 0.3 1</specular>
        </material>
      </visual>

      <!-- ======================================================== -->
      <!--  SCOOP (front-mounted, visual only)                      -->
      <!-- ======================================================== -->
      <visual name="scoop_visual">
        <pose>0.22 0 -0.04 0.52 0 0</pose>
        <geometry>
          <box>
            <size>0.10 0.20 0.005</size>
          </box>
        </geometry>
        <material>
          <ambient>0.7 0.7 0.7 1</ambient>
          <diffuse>0.8 0.8 0.8 1</diffuse>
        </material>
      </visual>

      <!-- ======================================================== -->
      <!--  COLLECTION BIN (top-mounted, visual only)               -->
      <!-- ======================================================== -->
      <visual name="bin_visual">
        <pose>-0.05 0 0.10 0 0 0</pose>
        <geometry>
          <box>
            <size>0.20 0.15 0.12</size>
          </box>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
        </material>
      </visual>

      <!-- ======================================================== -->
      <!--  ELECTRONICS ENCLOSURE (centre, visual only)             -->
      <!-- ======================================================== -->
      <visual name="enclosure_visual">
        <pose>0.05 0 0.10 0 0 0</pose>
        <geometry>
          <box>
            <size>0.12 0.10 0.08</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
        </material>
      </visual>

      <!-- ======================================================== -->
      <!--  CAMERA SENSOR (OV2640 on ESP32-CAM)                     -->
      <!-- ======================================================== -->
      <sensor name="camera" type="camera">
        <pose>0.20 0 0.10 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
          </image>
          <clip>
            <near>0.05</near>
            <far>50</far>
          </clip>
        </camera>
      </sensor>

      <!-- ======================================================== -->
      <!--  IMU SENSOR (MPU6050)                                    -->
      <!-- ======================================================== -->
      <sensor name="imu" type="imu">
        <always_on>true</always_on>
        <update_rate>50</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.05</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.05</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.05</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>

      <!-- ======================================================== -->
      <!--  FRONT ULTRASONIC SENSOR (HC-SR04)                       -->
      <!--  Approximated as a lidar ray sensor with narrow FOV      -->
      <!-- ======================================================== -->
      <sensor name="ultrasonic_front" type="gpu_lidar">
        <pose>0.20 0 0.05 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>1</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>0</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.02</min>
            <max>4.0</max>
            <resolution>0.003</resolution>
          </range>
        </lidar>
      </sensor>

      <!-- ======================================================== -->
      <!--  REAR ULTRASONIC SENSOR (HC-SR04)                        -->
      <!-- ======================================================== -->
      <sensor name="ultrasonic_rear" type="gpu_lidar">
        <pose>-0.20 0 0.05 0 3.14159 0</pose>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>1</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>0</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.02</min>
            <max>4.0</max>
            <resolution>0.003</resolution>
          </range>
        </lidar>
      </sensor>
    </link>

    <!-- ============================================================ -->
    <!--  LEFT TRACK (approximated as a wide cylinder/wheel)          -->
    <!--  Rubber caterpillar: 250mm long x 40mm wide                  -->
    <!--  Sprocket pitch radius: 20mm                                 -->
    <!-- ============================================================ -->
    <link name="left_track">
      <pose>0 0.175 0.04 -1.5708 0 0</pose>

      <inertial>
        <mass>2.0</mass>
        <inertia>
          <!-- Cylinder: r=0.04, h=0.04 -->
          <ixx>0.0011</ixx>
          <iyy>0.0011</iyy>
          <izz>0.0016</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="left_track_collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="left_track_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- ============================================================ -->
    <!--  RIGHT TRACK                                                 -->
    <!-- ============================================================ -->
    <link name="right_track">
      <pose>0 -0.175 0.04 -1.5708 0 0</pose>

      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0011</ixx>
          <iyy>0.0011</iyy>
          <izz>0.0016</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="right_track_collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="right_track_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- ============================================================ -->
    <!--  LEFT BRUSH ASSEMBLY (visual only)                           -->
    <!-- ============================================================ -->
    <link name="left_brush">
      <pose>0.10 0.14 0.02 -1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0002</ixx>
          <iyy>0.0002</iyy>
          <izz>0.0002</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="left_brush_visual">
        <geometry>
          <cylinder>
            <radius>0.03</radius>
            <length>0.02</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.2 1</ambient>
          <diffuse>0.7 0.7 0.3 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- ============================================================ -->
    <!--  RIGHT BRUSH ASSEMBLY (visual only)                          -->
    <!-- ============================================================ -->
    <link name="right_brush">
      <pose>0.10 -0.14 0.02 -1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0002</ixx>
          <iyy>0.0002</iyy>
          <izz>0.0002</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="right_brush_visual">
        <geometry>
          <cylinder>
            <radius>0.03</radius>
            <length>0.02</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.2 1</ambient>
          <diffuse>0.7 0.7 0.3 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- ============================================================ -->
    <!--  JOINTS                                                      -->
    <!-- ============================================================ -->

    <joint name="left_track_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_track</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <joint name="right_track_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_track</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <joint name="left_brush_joint" type="fixed">
      <parent>chassis</parent>
      <child>left_brush</child>
    </joint>

    <joint name="right_brush_joint" type="fixed">
      <parent>chassis</parent>
      <child>right_brush</child>
    </joint>

    <!-- ============================================================ -->
    <!--  DIFFERENTIAL DRIVE PLUGIN (skid-steer via tracks)           -->
    <!--  Simulates the L298N-driven track motors                     -->
    <!-- ============================================================ -->
    <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">
      <left_joint>left_track_joint</left_joint>
      <right_joint>right_track_joint</right_joint>
      <wheel_separation>0.35</wheel_separation>
      <wheel_radius>0.04</wheel_radius>
      <max_linear_acceleration>0.5</max_linear_acceleration>
      <max_angular_acceleration>1.0</max_angular_acceleration>
      <odom_publish_frequency>10</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
    </plugin>

    <!-- Sensor plugins -->
    <plugin
      filename="gz-sim-imu-system"
      name="gz::sim::systems::Imu">
    </plugin>

    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

  </model>
</sdf>
