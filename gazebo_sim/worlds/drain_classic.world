<?xml version="1.0"?>
<sdf version="1.6">
  <world name="drain_cleaning">

    <!-- Sun -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- Ground -->
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- Physics -->
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- Camera viewpoint -->
    <gui fullscreen="0">
      <camera name="user_camera">
        <pose>-5.5 -1.5 2.0 0 0.4 0.3</pose>
      </camera>
    </gui>

    <!-- ============================================ -->
    <!--  DRAIN CHANNEL                               -->
    <!--  Concrete U-channel: 450mm wide, 10m long    -->
    <!-- ============================================ -->

    <!-- Drain floor -->
    <model name="drain_floor">
      <static>true</static>
      <pose>0 0 -0.025 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>10.0 0.45 0.05</size></box></geometry>
          <surface>
            <friction><ode><mu>0.5</mu><mu2>0.5</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="vis">
          <geometry><box><size>10.0 0.45 0.05</size></box></geometry>
          <material>
            <ambient>0.6 0.6 0.55 1</ambient>
            <diffuse>0.7 0.7 0.65 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Left wall -->
    <model name="drain_left_wall">
      <static>true</static>
      <pose>0 0.25 0.125 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>10.0 0.05 0.30</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>10.0 0.05 0.30</size></box></geometry>
          <material>
            <ambient>0.55 0.55 0.50 1</ambient>
            <diffuse>0.65 0.65 0.60 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Right wall -->
    <model name="drain_right_wall">
      <static>true</static>
      <pose>0 -0.25 0.125 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>10.0 0.05 0.30</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>10.0 0.05 0.30</size></box></geometry>
          <material>
            <ambient>0.55 0.55 0.50 1</ambient>
            <diffuse>0.65 0.65 0.60 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Shallow water (visual only) -->
    <model name="water">
      <static>true</static>
      <pose>0 0 0.05 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>10.0 0.45 0.10</size></box></geometry>
          <material>
            <ambient>0.1 0.3 0.5 1</ambient>
            <diffuse>0.15 0.4 0.6 1</diffuse>
          </material>
          <transparency>0.6</transparency>
        </visual>
      </link>
    </model>

    <!-- Algae patch -->
    <model name="algae">
      <static>true</static>
      <pose>1.5 0.05 0.001 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>0.8 0.30 0.002</size></box></geometry>
          <material>
            <ambient>0.1 0.4 0.1 1</ambient>
            <diffuse>0.15 0.5 0.15 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================ -->
    <!--  AXIOM D1 ROBOT                              -->
    <!-- ============================================ -->
    <model name="axiom_d1">
      <pose>-4.0 0 0 0 0 0</pose>
      <static>false</static>

      <!-- Chassis -->
      <link name="chassis">
        <pose>0 0 0.12 0 0 0</pose>
        <inertial>
          <mass>10.0</mass>
          <inertia>
            <ixx>0.121</ixx><iyy>0.152</iyy><izz>0.235</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="col">
          <geometry><box><size>0.40 0.35 0.15</size></box></geometry>
        </collision>
        <visual name="chassis_vis">
          <geometry><box><size>0.40 0.35 0.15</size></box></geometry>
          <material>
            <ambient>1.0 0.5 0.0 1</ambient>
            <diffuse>1.0 0.5 0.0 1</diffuse>
          </material>
        </visual>
        <!-- Scoop -->
        <visual name="scoop_vis">
          <pose>0.22 0 -0.04 0.52 0 0</pose>
          <geometry><box><size>0.10 0.20 0.005</size></box></geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>
        <!-- Collection bin -->
        <visual name="bin_vis">
          <pose>-0.05 0 0.10 0 0 0</pose>
          <geometry><box><size>0.20 0.15 0.12</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.4 0.4 0.4 1</diffuse>
          </material>
        </visual>
        <!-- Electronics enclosure -->
        <visual name="enclosure_vis">
          <pose>0.05 0 0.10 0 0 0</pose>
          <geometry><box><size>0.12 0.10 0.08</size></box></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.15 0.15 0.15 1</diffuse>
          </material>
        </visual>

        <!-- Camera sensor -->
        <sensor name="camera" type="camera">
          <pose>0.20 0 0.05 0 0 0</pose>
          <always_on>true</always_on>
          <update_rate>15</update_rate>
          <camera>
            <horizontal_fov>1.047</horizontal_fov>
            <image><width>640</width><height>480</height></image>
            <clip><near>0.05</near><far>50</far></clip>
          </camera>
        </sensor>

        <!-- IMU sensor -->
        <sensor name="imu" type="imu">
          <always_on>true</always_on>
          <update_rate>50</update_rate>
        </sensor>
      </link>

      <!-- Left track (cylinder approximation of caterpillar track) -->
      <!-- Radius 0.06m, width 0.04m, at z=0.06 so bottom touches floor -->
      <link name="left_track">
        <pose>0 0.16 0.06 0 1.5708 1.5708</pose>
        <inertial>
          <mass>2.0</mass>
          <inertia>
            <ixx>0.002</ixx><iyy>0.004</iyy><izz>0.002</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <surface>
            <friction><ode><mu>1.5</mu><mu2>1.0</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>

      <!-- Right track -->
      <link name="right_track">
        <pose>0 -0.16 0.06 0 1.5708 1.5708</pose>
        <inertial>
          <mass>2.0</mass>
          <inertia>
            <ixx>0.002</ixx><iyy>0.004</iyy><izz>0.002</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <surface>
            <friction><ode><mu>1.5</mu><mu2>1.0</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>

      <!-- Left brush -->
      <link name="left_brush">
        <pose>0.10 0.14 0.02 0 1.5708 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.0002</ixx><iyy>0.0002</iyy><izz>0.0002</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="vis">
          <geometry><cylinder><radius>0.03</radius><length>0.02</length></cylinder></geometry>
          <material>
            <ambient>0.6 0.6 0.2 1</ambient>
            <diffuse>0.7 0.7 0.3 1</diffuse>
          </material>
        </visual>
      </link>

      <!-- Right brush -->
      <link name="right_brush">
        <pose>0.10 -0.14 0.02 0 1.5708 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.0002</ixx><iyy>0.0002</iyy><izz>0.0002</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="vis">
          <geometry><cylinder><radius>0.03</radius><length>0.02</length></cylinder></geometry>
          <material>
            <ambient>0.6 0.6 0.2 1</ambient>
            <diffuse>0.7 0.7 0.3 1</diffuse>
          </material>
        </visual>
      </link>

      <!-- Joints -->
      <joint name="left_track_joint" type="revolute">
        <parent>chassis</parent>
        <child>left_track</child>
        <axis><xyz>0 0 1</xyz></axis>
      </joint>

      <joint name="right_track_joint" type="revolute">
        <parent>chassis</parent>
        <child>right_track</child>
        <axis><xyz>0 0 1</xyz></axis>
      </joint>

      <joint name="left_brush_joint" type="fixed">
        <parent>chassis</parent>
        <child>left_brush</child>
      </joint>

      <joint name="right_brush_joint" type="fixed">
        <parent>chassis</parent>
        <child>right_brush</child>
      </joint>

      <!-- Differential drive plugin (Gazebo Classic) -->
      <plugin name="diff_drive" filename="libDiffDrivePlugin.so">
        <left_joint>left_track_joint</left_joint>
        <right_joint>right_track_joint</right_joint>
        <torque>12</torque>
      </plugin>


    </model>

    <!-- ============================================ -->
    <!--  DEBRIS                                      -->
    <!-- ============================================ -->

    <!-- Plastic bottle -->
    <model name="debris_bottle">
      <pose>2.0 0.05 0.06 0.3 0 0.5</pose>
      <link name="link">
        <inertial>
          <mass>0.03</mass>
          <inertia>
            <ixx>0.00001</ixx><iyy>0.00001</iyy><izz>0.000005</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.035</radius><length>0.12</length></cylinder></geometry>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.035</radius><length>0.12</length></cylinder></geometry>
          <material>
            <ambient>0.2 0.6 0.8 1</ambient>
            <diffuse>0.3 0.7 0.9 1</diffuse>
          </material>
          <transparency>0.3</transparency>
        </visual>
      </link>
    </model>

    <!-- Organic debris -->
    <model name="debris_organic">
      <pose>3.5 0.10 0.04 0 0 0.8</pose>
      <link name="link">
        <inertial>
          <mass>0.15</mass>
          <inertia>
            <ixx>0.00005</ixx><iyy>0.00005</iyy><izz>0.00005</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="col">
          <geometry><sphere><radius>0.06</radius></sphere></geometry>
        </collision>
        <visual name="vis">
          <geometry><sphere><radius>0.06</radius></sphere></geometry>
          <material>
            <ambient>0.3 0.2 0.1 1</ambient>
            <diffuse>0.4 0.25 0.12 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Plastic bag -->
    <model name="debris_bag">
      <pose>0.5 -0.05 0.03 0 0 0.3</pose>
      <link name="link">
        <inertial>
          <mass>0.01</mass>
          <inertia>
            <ixx>0.000005</ixx><iyy>0.000005</iyy><izz>0.000002</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="col">
          <geometry><box><size>0.15 0.12 0.005</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.15 0.12 0.005</size></box></geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.9 0.9 0.9 1</diffuse>
          </material>
          <transparency>0.4</transparency>
        </visual>
      </link>
    </model>

  </world>
</sdf>
