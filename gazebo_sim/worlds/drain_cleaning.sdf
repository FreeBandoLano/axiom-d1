<?xml version="1.0"?>
<sdf version="1.9">
  <world name="drain_cleaning">

    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>

    <scene>
      <ambient>0.6 0.6 0.6 1</ambient>
      <background>0.4 0.7 0.9 1</background>
      <shadows>true</shadows>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1.0 0.95 0.85 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <direction>-0.5 0.3 -1.0</direction>
    </light>

    <!-- Ground plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="ground_link">
        <collision name="ground_collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>50 50</size></plane>
          </geometry>
        </collision>
        <visual name="ground_visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>50 50</size></plane>
          </geometry>
          <material>
            <ambient>0.35 0.45 0.25 1</ambient>
            <diffuse>0.4 0.5 0.3 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Drain channel (inline, no include) -->
    <model name="drain_channel">
      <static>true</static>
      <pose>0 0 -0.025 0 0 0</pose>

      <link name="floor">
        <collision name="floor_col">
          <geometry><box><size>10.0 0.45 0.05</size></box></geometry>
          <surface><friction><ode><mu>0.5</mu><mu2>0.5</mu2></ode></friction></surface>
        </collision>
        <visual name="floor_vis">
          <geometry><box><size>10.0 0.45 0.05</size></box></geometry>
          <material>
            <ambient>0.6 0.6 0.55 1</ambient>
            <diffuse>0.7 0.7 0.65 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="left_wall">
        <pose>0 0.25 0.15 0 0 0</pose>
        <collision name="lw_col">
          <geometry><box><size>10.0 0.05 0.30</size></box></geometry>
        </collision>
        <visual name="lw_vis">
          <geometry><box><size>10.0 0.05 0.30</size></box></geometry>
          <material>
            <ambient>0.55 0.55 0.50 1</ambient>
            <diffuse>0.65 0.65 0.60 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="right_wall">
        <pose>0 -0.25 0.15 0 0 0</pose>
        <collision name="rw_col">
          <geometry><box><size>10.0 0.05 0.30</size></box></geometry>
        </collision>
        <visual name="rw_vis">
          <geometry><box><size>10.0 0.05 0.30</size></box></geometry>
          <material>
            <ambient>0.55 0.55 0.50 1</ambient>
            <diffuse>0.65 0.65 0.60 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="water">
        <pose>0 0 0.075 0 0 0</pose>
        <visual name="water_vis">
          <geometry><box><size>10.0 0.45 0.10</size></box></geometry>
          <material>
            <ambient>0.1 0.3 0.5 0.4</ambient>
            <diffuse>0.15 0.4 0.6 0.4</diffuse>
          </material>
          <transparency>0.6</transparency>
        </visual>
      </link>
    </model>

    <!-- AXIOM D1 robot (inline, simplified — no sensors yet) -->
    <model name="axiom_d1">
      <pose>-4.0 0 0.05 0 0 0</pose>
      <static>false</static>

      <link name="chassis">
        <pose>0 0 0.075 0 0 0</pose>
        <inertial>
          <mass>10.0</mass>
          <inertia>
            <ixx>0.121</ixx><iyy>0.152</iyy><izz>0.235</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="chassis_col">
          <geometry><box><size>0.40 0.35 0.15</size></box></geometry>
        </collision>
        <visual name="chassis_vis">
          <geometry><box><size>0.40 0.35 0.15</size></box></geometry>
          <material>
            <ambient>1.0 0.5 0.0 1</ambient>
            <diffuse>1.0 0.5 0.0 1</diffuse>
          </material>
        </visual>
        <!-- Scoop -->
        <visual name="scoop_vis">
          <pose>0.22 0 -0.04 0.52 0 0</pose>
          <geometry><box><size>0.10 0.20 0.005</size></box></geometry>
          <material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material>
        </visual>
        <!-- Collection bin -->
        <visual name="bin_vis">
          <pose>-0.05 0 0.10 0 0 0</pose>
          <geometry><box><size>0.20 0.15 0.12</size></box></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
        </visual>
        <!-- Electronics enclosure -->
        <visual name="enclosure_vis">
          <pose>0.05 0 0.10 0 0 0</pose>
          <geometry><box><size>0.12 0.10 0.08</size></box></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
        </visual>
      </link>

      <link name="left_track">
        <pose>0 0.175 0.04 -1.5708 0 0</pose>
        <inertial>
          <mass>2.0</mass>
          <inertia>
            <ixx>0.0011</ixx><iyy>0.0011</iyy><izz>0.0016</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="lt_col">
          <geometry><cylinder><radius>0.04</radius><length>0.04</length></cylinder></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface>
        </collision>
        <visual name="lt_vis">
          <geometry><cylinder><radius>0.04</radius><length>0.04</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
        </visual>
      </link>

      <link name="right_track">
        <pose>0 -0.175 0.04 -1.5708 0 0</pose>
        <inertial>
          <mass>2.0</mass>
          <inertia>
            <ixx>0.0011</ixx><iyy>0.0011</iyy><izz>0.0016</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="rt_col">
          <geometry><cylinder><radius>0.04</radius><length>0.04</length></cylinder></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface>
        </collision>
        <visual name="rt_vis">
          <geometry><cylinder><radius>0.04</radius><length>0.04</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
        </visual>
      </link>

      <joint name="left_track_joint" type="revolute">
        <parent>chassis</parent>
        <child>left_track</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        </axis>
      </joint>

      <joint name="right_track_joint" type="revolute">
        <parent>chassis</parent>
        <child>right_track</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        </axis>
      </joint>

      <plugin filename="gz-sim-diff-drive-system"
              name="gz::sim::systems::DiffDrive">
        <left_joint>left_track_joint</left_joint>
        <right_joint>right_track_joint</right_joint>
        <wheel_separation>0.35</wheel_separation>
        <wheel_radius>0.04</wheel_radius>
        <max_linear_acceleration>0.5</max_linear_acceleration>
        <odom_publish_frequency>10</odom_publish_frequency>
        <topic>cmd_vel</topic>
      </plugin>
    </model>

    <!-- Debris -->
    <model name="debris_bottle">
      <static>false</static>
      <pose>2.0 0.05 0.06 0.3 0 0.5</pose>
      <link name="link">
        <inertial>
          <mass>0.03</mass>
          <inertia><ixx>0.00001</ixx><iyy>0.00001</iyy><izz>0.000005</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <collision name="col"><geometry><cylinder><radius>0.035</radius><length>0.12</length></cylinder></geometry></collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.035</radius><length>0.12</length></cylinder></geometry>
          <material><ambient>0.2 0.6 0.8 0.8</ambient><diffuse>0.3 0.7 0.9 0.8</diffuse></material>
          <transparency>0.3</transparency>
        </visual>
      </link>
    </model>

  </world>
</sdf>
